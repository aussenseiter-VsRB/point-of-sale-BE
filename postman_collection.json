            "description": "Get a single transaction with all line items."
          }
        },
        {
          "name": "Create Transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('transaksi_id', jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_kasir\": {{kasir_id}},\n  \"items\": [\n    {\n      \"id_produk\": \"{{produk_id}}\",\n      \"jumlah\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/transaksi",
              "host": ["{{base_url}}"],
              "path": ["transaksi"]
            },
            "description": "Create a sale transaction. Validates stock availability, then DECREMENTS product stock.\n\nNote: Use id_produk (UUID) for each item. If using barcode scanner, first GET /produk/barcode/:code to get the produk_id.\n\nOptional discount fields: discount_amount, discount_reason, discount_approved_by (required if discount > 10% of subtotal)."
          }
        },
        {
          "name": "Create Transaction with Discount",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_kasir\": {{kasir_id}},\n  \"items\": [\n    {\n      \"id_produk\": \"{{produk_id}}\",\n      \"jumlah\": 2\n    }\n  ],\n  \"discount_amount\": 1000,\n  \"discount_reason\": \"Promo weekend\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transaksi",
              "host": ["{{base_url}}"],
              "path": ["transaksi"]
            },
            "description": "Create transaction with discount. Discount ≤10% of subtotal = auto-approved. Discount >10% requires discount_approved_by (admin UUID)."
          }
        },
        {
          "name": "Soft-Delete Transaction (Void)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Customer returned items\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transaksi/{{transaksi_id}}",
              "host": ["{{base_url}}"],
              "path": ["transaksi", "{{transaksi_id}}"]
            },
            "description": "Soft-delete (void) a transaction. Accepts JSON body with 'reason' (required). Creates a void_log entry before deleting. Reason must not be empty."
          }
        },
        {
          "name": "Get Discounted Transactions [ADMIN]",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
