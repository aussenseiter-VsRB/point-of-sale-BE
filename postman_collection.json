              "raw": "{{base_url}}/transaksi/discounted",
              "host": ["{{base_url}}"],
              "path": ["transaksi", "discounted"]
            },
            "description": "List all transactions where discount_amount > 0, ordered by discount_amount DESC. ADMIN ONLY."
          }
        }
      ],
      "description": "Transaction/Sale management. Accessible by all authenticated users (admin + kasir)."
    },
