          }
        },
        {
          "name": "Create Restock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_produk\": \"{{produk_id}}\",\n  \"jumlah_beli\": 5,\n  \"jumlah_satuan\": 24,\n  \"harga_beli\": 2500,\n  \"supplier\": \"PT Indofood\",\n  \"keterangan\": \"Restock bulanan\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stok-masuk",
              "host": ["{{base_url}}"],
              "path": ["stok-masuk"]
            },
            "description": "Record stock intake. Automatically INCREMENTS product stock.\n\n- jumlah_beli = how many boxes/units purchased\n- jumlah_satuan = items per box (e.g., 24 pcs per box) → defaults to 1\n- Total stock added: jumlah_beli * jumlah_satuan\n- id_user (who did it) is auto-taken from JWT token\n\nFor Excel-based bulk restock: Frontend parses Excel, then POST one-by-one or in batch."
          }
        }
      ],
      "description": "Restock / Stock Intake. Records inventory purchases and auto-updates produk.stok. Accessible by all authenticated users."
    },
